  "publicApiSurface": [
    "list-projects — List all configured projects",
    "set-active <name> — Set the active project",
    "generate [since] — Generate worklog for specified date range",
    "loadConfig() — Load projects configuration",
    "saveConfig(cfg) — Save projects configuration",
    "parseSinceDate(input) — Parse date inputs to ISO format",
    "getCommitHashes(repoPath, since) — Get commit hashes since date",
    "getCommitDiff(repoPath, commitHash) — Get diff for a commit",
    "callGemini(promptText) — Call Gemini CLI with prompt"
